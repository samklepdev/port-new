{
  "name": "port-new-backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "migrate:up": "node-pg-migrate up -m db/migrations",
    "migrate:down": "node-pg-migrate down -m db/migrations",
    "migrate:create": "node-pg-migrate create -m db/migrations",
    "seed:admin": "tsx ./src/db/seed.ts",
    "test": "tsx ./src/tests/run-all-tests.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/sequelize": "^4.28.20",
    "@types/uuid": "^10.0.0",
    "sequelize-cli": "^6.6.5",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
